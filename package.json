{
  "name": "har-extractor",
  "version": "1.0.0",
  "type": "commonjs",
  "bin": {
    "har-extract": "dist/har-extract.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/har-extract.js ./input/session.har --name-list ./input/names.txt --clean --keep-dirs --log-level debug --log-file ./output/extract.log --manifest ./output/manifest.json",
    "dev": "ts-node src/har-extract.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0"
  }
}
